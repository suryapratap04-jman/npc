# Database Configurations (defaults for Docker Compose; change to 'localhost' for local tests)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resource_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Vector Database (defaults for Docker Compose; change to 'localhost' for local tests)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama Orchestration (defaults for Docker Compose; change to 'localhost' for local tests)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:7b

# AI Embeddings
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# LLM Providers Configuration 
LLM_PROVIDER=ollama

# Optional cloud provider keys 
GEMINI_API_KEY=
GROK_API_KEY=
