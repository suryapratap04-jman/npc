# ==============================================================================
# AI RESOURCE MANAGEMENT PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and modify settings for local vs docker deployments.
# NEVER commit raw secrets or API keys to repository history.
# ==============================================================================

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Next.js)
# ------------------------------------------------------------------------------
# API address accessible from the browser client context
NEXT_PUBLIC_API_URL=http://localhost:8000
PORT=3000

# ------------------------------------------------------------------------------
# BACKEND CONFIGURATION (FastAPI)
# ------------------------------------------------------------------------------
# Set to 'true' if running inside docker container network
RUNNING_IN_DOCKER=true

# ------------------------------------------------------------------------------
# RELATIONAL DATABASE CONFIGURATION (PostgreSQL)
# ------------------------------------------------------------------------------
# Use 'db' when running in docker compose; use 'localhost' for local direct tests
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resource_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Direct database connection URL (falls back to host/user/port computed values if empty)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resource_db

# ------------------------------------------------------------------------------
# VECTOR DATABASE CONFIGURATION (Qdrant)
# ------------------------------------------------------------------------------
# Use 'qdrant' when running in docker compose; use 'localhost' for local direct tests
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ------------------------------------------------------------------------------
# LOCAL LLM CONFIGURATION (Ollama)
# ------------------------------------------------------------------------------
# Use 'ollama' when running in docker compose; use 'localhost' for local direct tests
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:7b

# AI Embeddings SentenceTransformer Model settings (runs locally in Python backend context)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ------------------------------------------------------------------------------
# CLOUD LLM PROVIDERS CONFIGURATION (Optional overrides)
# ------------------------------------------------------------------------------
# Options: ollama, gemini, grok
LLM_PROVIDER=ollama

# API Keys (Provide only if LLM_PROVIDER is set to gemini or grok)
GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_grok_api_key_here
